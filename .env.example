# ─── Agora ────────────────────────────────────────────────────────────────────
# Required: found in Agora Console → your project → "App ID"
NEXT_PUBLIC_AGORA_APP_ID=

# Required: found in Agora Console → your project → "App Certificate"
# Server-side only. Never expose this in client code.
NEXT_AGORA_APP_CERTIFICATE=

# Optional: RTC channel used by browser viewers, Media Gateway, and the backend
# commentator. Defaults to worldcup-live.
# NEXT_PUBLIC_LIVE_CHANNEL_NAME=worldcup-live

# Optional: override the default RTC UIDs in lib/agora.ts. Only change these if
# your Agora Media Gateway feed or backend agent uses different fixed UIDs.
# NEXT_PUBLIC_AGENT_UID=123456
# NEXT_PUBLIC_MATCH_FEED_UID=234567

# Optional: restrict Web SDK routing. Leave unset or set global for automatic
# edge selection. Keep RTMP ingest in EU separately when the encoder is in Europe.
# Supported shorthand values include cn, as, na, eu, jp, in.
# NEXT_PUBLIC_AGORA_AREA_CODE=global

# Local-only helper for `pnpm run media-gateway:key`. These Agora RESTful API
# credentials create an RTMP stream key for OBS/ffmpeg. They are not used by the
# app at runtime and should not be added to Vercel.
# AGORA_CUSTOMER_ID=
# AGORA_CUSTOMER_SECRET=
# Choose the Media Gateway region closest to your encoder. Common values:
# eu, na, as, cn, jp, in.
# AGORA_MEDIA_GATEWAY_REGION=<region>
# AGORA_MEDIA_GATEWAY_STREAM_KEY_TTL=2592000

# Python/Railway backend that joins the Agora RTC channel and starts the vision
# commentator.
# Local default used by API routes when unset: http://localhost:8000
AGENT_BACKEND_URL=http://localhost:8000

# Shared secret sent from Next.js API routes to the Python backend. Set the same
# value in server/.env.local or Railway before exposing the backend publicly.
# Generate one locally with: openssl rand -hex 32
BACKEND_API_SECRET=

# Required access gate while the live booth is in private preview. Validated
# server-side in app/api routes; comparison is trimmed and case-insensitive.
# Set this in Vercel. There is no hard-coded fallback password.
ACCESS_PASSWORD=
# Optional HMAC secret and TTL for the httpOnly access cookie issued after the
# access code is accepted. Defaults to ACCESS_PASSWORD and 12 hours.
# ACCESS_SESSION_SECRET=
# ACCESS_SESSION_TTL_SECONDS=43200

# Backend-only AI, voice, pacing, and cost-control variables belong in
# server/.env.local or Railway. See server/.env.example.
