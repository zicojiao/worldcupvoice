# Required: Agora project credentials
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Required: OpenAI key used for vision and the default OpenAI TTS voice
OPENAI_API_KEY=

# Required for public deployments. Set the same value in the Next.js/Vercel
# environment so only the frontend proxy can control backend sessions.
# Generate one locally with: openssl rand -hex 32
BACKEND_API_SECRET=

# Optional: Agora routing / fixed UID overrides. Defaults are defined in
# server/app/config.py and lib/agora.ts; only change these if your Media Gateway
# or backend agent uses different reserved UIDs.
# AGORA_AREA_CODE=global
# AGENT_UID=123456
# MATCH_FEED_UID=234567

# Optional: ElevenLabs sportscaster voice instead of the default OpenAI TTS.
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_VOICE_ID_EN_SPORTSCASTER=

# Optional: Fish Audio voice instead of the default OpenAI TTS. This is useful
# for Chinese voices; output stays raw PCM for direct Agora publishing. Create
# your own Fish Audio voices and fill the profile-specific IDs below.
# TTS_PROVIDER=fish_audio
# FISH_AUDIO_API_KEY=
# FISH_AUDIO_VOICE_ID=
# FISH_AUDIO_VOICE_ID_ZH_MEME=
# FISH_AUDIO_VOICE_ID_ZH_TACTICAL=
# FISH_AUDIO_MODEL=s2-pro
# FISH_AUDIO_LATENCY=balanced
# FISH_AUDIO_CHUNK_LENGTH=150

# Advanced model, pacing, audio, heartbeat, and session TTL defaults live in
# server/app/config.py. Override them only when you are deliberately tuning the
# runtime.
